<?xml version="1.0" encoding="ISO-8859-1"?>
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">

  <xsd:simpleType name="DataFormatoBrasil">
    <xsd:restriction base="xsd:string">
      <xsd:length value="10"/>
      <xsd:pattern value="(((0[1-9]|[1,2][0-9])/02)|((0[1-9]|[1,2][0-9]|30)/(0[4,6,9]|11))|((0[1-9]|[1,2][0-9]|3[0,1])/(0[1,3,5,7,8]|1[0,2])))/[1,2][0-9]{3}"/>
    </xsd:restriction>
  </xsd:simpleType>


  <xsd:simpleType name="DataHora">
  <xsd:restriction base="xsd:string">
    <xsd:length value="19"/>
    <xsd:pattern value="((0[1-9])|([12][0-9])|(3[01]))/((0[1-9])|(1[012]))/((000[1-9])|(00[1-9][0-9])|(0[1-9][0-9]{2})|([1-9][0-9]{3})) (([01][0-9])|(2[0-3]))(:[0-5][0-9]){2}(\.[0-9]+)?" />
  </xsd:restriction>
</xsd:simpleType>

  <xsd:simpleType name="FormatoSeloOriginal">
    <xsd:restriction base="xsd:string">
	  <xsd:minLength value="8"/>
	  <xsd:maxLength value="9"/>
      <xsd:pattern value="^[A-Z]{3,4}[0-9]{5}$"/>
    </xsd:restriction>
  </xsd:simpleType>

  <xsd:simpleType name="FormatoSelo">
    <xsd:restriction base="xsd:string">
      <xsd:length value="9"/>
      <xsd:pattern value="^[A-Z]{4}[0-9]{5}$"/>
    </xsd:restriction>
  </xsd:simpleType>

  <xsd:simpleType name="FormatoAleatorio">
    <xsd:restriction base="xsd:string">
      <xsd:length value="3"/>
      <xsd:pattern value="^[A-Z]{3}$"/>
    </xsd:restriction>
  </xsd:simpleType>

  <xsd:simpleType name="CodigoServico">
    <xsd:restriction base="xsd:string">
      <xsd:maxLength value="5"/>
      <xsd:pattern value="^[0-9]{1,5}$"/>
    </xsd:restriction>
  </xsd:simpleType>

    <xsd:simpleType name="ValorDecimal">
		<xsd:restriction base="xsd:decimal">
			<xsd:fractionDigits value="2"/>
			<xsd:minInclusive value="0"/>
			<xsd:totalDigits value="12"/>
		</xsd:restriction>
	</xsd:simpleType>

	<xsd:simpleType name="string250">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="2"/>
			<xsd:maxLength value="250"/>
		</xsd:restriction>
	</xsd:simpleType>

	<xsd:simpleType name="string25">
		<xsd:restriction base="xsd:string">
			<xsd:minLength value="1"/>
			<xsd:maxLength value="25"/>
		</xsd:restriction>
	</xsd:simpleType>

	<xsd:simpleType name="IndicadorSimNao">
		  <xsd:restriction base="xsd:string">
			<xsd:enumeration value="S" />
			<xsd:enumeration value="N" />
		  </xsd:restriction>
	</xsd:simpleType>

  <!-- Define o tipo complexo  -->

  <xsd:complexType name="Ato">
	<xsd:attribute name="DataPratica" use="required">
	  <xsd:simpleType>
		<xsd:restriction base="DataFormatoBrasil"/>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="Selo" use="required">
	  <xsd:simpleType>
		<xsd:restriction base="FormatoSelo"/>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="Aleatorio" use="required">
	  <xsd:simpleType>
		<xsd:restriction base="FormatoAleatorio"/>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="CodServicoAtoOriginal">
	  <xsd:simpleType>
		<xsd:restriction base="CodigoServico"/>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="SeloAtoOriginal">
	  <xsd:simpleType>
		<xsd:restriction base="FormatoSeloOriginal"/>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="AleatorioAtoOriginal">
	  <xsd:simpleType>
		<xsd:restriction base="FormatoAleatorio"/>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="CodServicoAtoReferencia">
	  <xsd:simpleType>
		<xsd:restriction base="CodigoServico"/>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="SeloAtoReferencia">
	  <xsd:simpleType>
		<xsd:restriction base="FormatoSeloOriginal"/>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="AleatorioAtoReferencia">
	  <xsd:simpleType>
		<xsd:restriction base="FormatoAleatorio"/>
	  </xsd:simpleType>
	</xsd:attribute>
	 <xsd:attribute name="Livro">
 	  <xsd:simpleType>
		<xsd:restriction base="string25"/>
	  </xsd:simpleType>
     </xsd:attribute>
	<xsd:attribute name="Folha">
	  <xsd:simpleType>
		<xsd:restriction base="string25"/>
	  </xsd:simpleType>
	</xsd:attribute>
  <xsd:attribute name="Termo">
      <xsd:simpleType>
        <xsd:restriction base="xsd:string">
          <xsd:minLength value="1"/>
          <xsd:maxLength value="10"/>
          <xsd:pattern value="^[0-9]{1,10}$"/>
        </xsd:restriction>
      </xsd:simpleType>
  </xsd:attribute>
	<xsd:attribute name="MatriculaNacional">
		<xsd:simpleType>
       <xsd:restriction base="xsd:string">
          <xsd:length fixed="true" value="32"/>
       </xsd:restriction>
    </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="TipoLivro">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
			<xsd:maxLength value="1" />
			<xsd:pattern value="^[1-9]"/>
          </xsd:restriction>
        </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="OrdemJudicial">
		<xsd:simpleType>
		   <xsd:restriction base="IndicadorSimNao"/>
	    </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="NumeroProcessoJudicial">
		 <xsd:simpleType>
	         <xsd:restriction base="string25"/>
	     </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="DataSentencaDecisao">
      <xsd:simpleType>
        <xsd:restriction base="DataFormatoBrasil"/>
      </xsd:simpleType>
    </xsd:attribute>
	<xsd:attribute name="Observacoes">
		<xsd:simpleType>
		  <xsd:restriction base="xsd:string">
			<xsd:minLength value="2"/>
			<xsd:maxLength value="4000"/>
		  </xsd:restriction>
        </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="IndCertidaoEletronica" >
	  <xsd:simpleType>
		<xsd:restriction base="xsd:string">
		  <xsd:enumeration value="S"/>
		</xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="IndAtoEletronico" >
	  <xsd:simpleType>
		<xsd:restriction base="xsd:string">
		  <xsd:enumeration value="S"/>
		  <xsd:enumeration value="N"/>
		</xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="UrlPDFAto" >
	  <xsd:simpleType>
		<xsd:restriction base="xsd:string">
		   <xsd:minLength value="2"/>
		   <xsd:maxLength value="2083"/>
		</xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="HashPDFAto" >
	  <xsd:simpleType>
		 <xsd:restriction base="xsd:string">
          <xsd:length fixed="true" value="64"/>
         </xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="UrlDossie" >
	  <xsd:simpleType>
		<xsd:restriction base="xsd:string">
		   <xsd:minLength value="2"/>
		   <xsd:maxLength value="2083"/>
		</xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="HashDossie" >
	  <xsd:simpleType>
		 <xsd:restriction base="xsd:string">
          <xsd:length fixed="true" value="64"/>
         </xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
  </xsd:complexType>

  <xsd:complexType name="Transmissao" abstract="true">
    <xsd:attribute name="DataPratica" use="required">
      <xsd:simpleType>
        <xsd:restriction base="DataFormatoBrasil"/>
      </xsd:simpleType>
    </xsd:attribute>
    <xsd:attribute name="CCT" use="required">
      <xsd:simpleType>
        <xsd:restriction base="FormatoSelo"/>
      </xsd:simpleType>
    </xsd:attribute>
	<xsd:attribute name="IndAtoEletronico" >
	  <xsd:simpleType>
		<xsd:restriction base="xsd:string">
		  <xsd:enumeration value="S"/>
		  <xsd:enumeration value="N"/>
		</xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="UrlPDFAto" >
	  <xsd:simpleType>
		<xsd:restriction base="xsd:string">
		   <xsd:minLength value="2"/>
		   <xsd:maxLength value="2083"/>
		</xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="HashPDFAto" >
	  <xsd:simpleType>
		 <xsd:restriction base="xsd:string">
          <xsd:length fixed="true" value="64"/>
         </xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="UrlDossie" >
	  <xsd:simpleType>
		<xsd:restriction base="xsd:string">
		   <xsd:minLength value="2"/>
		   <xsd:maxLength value="2083"/>
		</xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
	<xsd:attribute name="HashDossie" >
	  <xsd:simpleType>
		 <xsd:restriction base="xsd:string">
          <xsd:length fixed="true" value="64"/>
         </xsd:restriction>
	  </xsd:simpleType>
	</xsd:attribute>
  </xsd:complexType>

  <xsd:complexType name="ElementoJustificativaAtoNaoPraticado">
	<xsd:attribute name="Data" use="required">
	  <xsd:simpleType>
		<xsd:restriction base="DataFormatoBrasil"/>
	  </xsd:simpleType>
	</xsd:attribute>
  </xsd:complexType>

  <!-- TIPOS DE ATOS -->
  <xsd:complexType name="AtoRegistroNascimento">
	<xsd:complexContent>
		<xsd:extension base="Ato">
			<xsd:sequence>
				<xsd:element name="Nascido" type="tpPessoa" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="Testemunhas" type="tpTestemunhas" minOccurs="0" maxOccurs="1"/>
				<xsd:element name="ImpressosSeguranca" type="tpImpressosSeguranca" minOccurs="0" maxOccurs="1"/>
				<xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
			</xsd:sequence>
			<xsd:attribute name="TipoDocumento" use="required">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:enumeration value="1"/>
						<xsd:enumeration value="2"/>
						<xsd:enumeration value="3"/>
						<xsd:enumeration value="4"/>
						<xsd:enumeration value="5"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:attribute>
			<xsd:attribute name="NumeroDocumento">
				<xsd:simpleType>
		           <xsd:restriction base="string25"/>
	            </xsd:simpleType>
			</xsd:attribute>
			<xsd:attribute name="ProtocoloConsultaDNV">
				<xsd:simpleType>
		           <xsd:restriction base="string25"/>
	            </xsd:simpleType>
			</xsd:attribute>
            <xsd:attribute name="NumeroRgAtribuido">
				 <xsd:simpleType>
		           <xsd:restriction base="string25"/>
	             </xsd:simpleType>
			</xsd:attribute>
			<xsd:attribute name="NumeroGemeos">
             <xsd:simpleType>
              <xsd:restriction base="xsd:string">
                <xsd:minLength value="1"/>
                <xsd:maxLength value="1"/>
                <xsd:pattern value="^[0-9]{1,1}$"/>
              </xsd:restriction>
             </xsd:simpleType>
            </xsd:attribute>
			<xsd:attribute name="Local">
             <xsd:simpleType>
              <xsd:restriction base="xsd:string">
                <xsd:enumeration value="1"/>
				<xsd:enumeration value="2"/>
              </xsd:restriction>
             </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="HoraNascimento">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
					<xsd:minLength value="1"/>
					<xsd:maxLength value="5"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:attribute>
			<xsd:attribute name="IndIndigena" use="required">
				<xsd:simpleType>
					<xsd:restriction base="IndicadorSimNao"/>
				</xsd:simpleType>
			</xsd:attribute>
		</xsd:extension>
	</xsd:complexContent>
  </xsd:complexType>

    <xsd:complexType name="AtoRegistroTranscricaoNascimento">
	<xsd:complexContent>
		<xsd:extension base="Ato">
			<xsd:sequence>
				<xsd:element name="DescricaoTranscricao" type="tpDescricaoTranscricao" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="Nascido" type="tpPessoa" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
			</xsd:sequence>
		</xsd:extension>
	</xsd:complexContent>
  </xsd:complexType>

  <xsd:complexType name="AtoCertidaoNascimento">
	<xsd:complexContent>
		<xsd:extension base="Ato">
		<xsd:sequence>
				<xsd:element name="Nascido" type="tpPessoa" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
		</xsd:sequence>
			<xsd:attribute name="TipoAto" use="required">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:enumeration value="RCN"/>
						<xsd:enumeration value="RCTN"/>
						<xsd:enumeration value="RCUI"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:attribute>
			<xsd:attribute name="IndInterligacao" use="required">
				<xsd:simpleType>
		           <xsd:restriction base="IndicadorSimNao"/>
	            </xsd:simpleType>
			</xsd:attribute>
			<xsd:attribute name="IndInteiroTeor" use="required">
				<xsd:simpleType>
		          <xsd:restriction base="IndicadorSimNao"/>
	            </xsd:simpleType>
			</xsd:attribute>
		</xsd:extension>
	</xsd:complexContent>
  </xsd:complexType>

  <xsd:complexType name="AtoAverbacaoNascimento">
	<xsd:complexContent>
		<xsd:extension base="Ato">
		<xsd:sequence>
				<xsd:element name="Nascido" type="tpPessoa" minOccurs="1" maxOccurs="1"/>
    	        <xsd:element name="AtosVinculados" type="tpAtosVinculados" minOccurs="0" maxOccurs="1"/>
                <xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
		</xsd:sequence>
			<xsd:attribute name="TipoAto" use="required">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:enumeration value="RAN"/>
						<xsd:enumeration value="RATN"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:attribute>
			<xsd:attribute name="TipoAverbacao" use="required">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:enumeration value="N1"/>
						<xsd:enumeration value="N2"/>
						<xsd:enumeration value="N3"/>
						<xsd:enumeration value="N4"/>
						<xsd:enumeration value="N5"/>
						<xsd:enumeration value="N6"/>
						<xsd:enumeration value="N7"/>
						<xsd:enumeration value="N8"/>
						<xsd:enumeration value="N9"/>
						<xsd:enumeration value="N10"/>						
						<xsd:enumeration value="N11"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:attribute>
			<xsd:attribute name="NumeroProcesso">
				<xsd:simpleType>
		          <xsd:restriction base="string25"/>
	            </xsd:simpleType>
			</xsd:attribute>
			<xsd:attribute name="NomeServicoReconhecimento">
				<xsd:simpleType>
		          <xsd:restriction base="string250"/>
	            </xsd:simpleType>
			</xsd:attribute>
		</xsd:extension>
	</xsd:complexContent>
  </xsd:complexType>

    <xsd:complexType name="AtoProcessoPaternidadePS">
	<xsd:complexContent>
		<xsd:extension base="Ato">
		<xsd:sequence>
				<xsd:element name="Genitor" type="tpPessoa" minOccurs="0" maxOccurs="2"/>
				<xsd:element name="Nascido" type="tpPessoa" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
		</xsd:sequence>
			<xsd:attribute name="TipoProcesso" use="required">
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:enumeration value="R2"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:attribute>
		</xsd:extension>
	</xsd:complexContent>
  </xsd:complexType>
  
  <xsd:complexType name="AtoAVO">
    <xsd:complexContent>
      <xsd:extension base="Transmissao">
        <xsd:sequence>
          <xsd:element name="Genitor" type="tpPessoa" minOccurs="0" maxOccurs="2"/>
		  <xsd:element name="Nascido" type="tpPessoa" minOccurs="1" maxOccurs="1"/>
		  <xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
        </xsd:sequence>
        <xsd:attribute name="IndicacaoPaternidade" use="required">
			<xsd:simpleType>
		      <xsd:restriction base="IndicadorSimNao"/>
	        </xsd:simpleType>
		</xsd:attribute>
      </xsd:extension>
    </xsd:complexContent>
  </xsd:complexType>

<xsd:complexType name="AtoProcessoPaternidadeOS">
	<xsd:complexContent>
		<xsd:extension base="Ato">
		<xsd:sequence>
				<xsd:element name="Genitor" type="tpPessoa" minOccurs="1" maxOccurs="2"/>
				<xsd:element name="Nascido" type="tpPessoa" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
		</xsd:sequence>
		<xsd:attribute name="CodServico">
			<xsd:simpleType>
				<xsd:restriction base="CodigoServico"/>
			</xsd:simpleType>
		</xsd:attribute>
	  <xsd:attribute name="NomeServicoOriginal">
		    <xsd:simpleType>
		         <xsd:restriction base="string250"/>
	        </xsd:simpleType>
	  </xsd:attribute>
      <xsd:attribute name="EstadoServicoOriginal">
        <xsd:simpleType>
          <xsd:restriction base="xsd:string">
            <xsd:length fixed="true" value="2"/>
          </xsd:restriction>
        </xsd:simpleType>
      </xsd:attribute>
		</xsd:extension>
	</xsd:complexContent>
  </xsd:complexType>

  <xsd:complexType name="AtoHabilitacaoCasamento">
	<xsd:complexContent>
		<xsd:extension base="Ato">
		<xsd:sequence>
				<xsd:element name="Conjuges" type="tpConjuge" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
		</xsd:sequence>
		<xsd:attribute name="ProcessoHabilitacao" use="required">
			<xsd:simpleType>
		       <xsd:restriction base="string25"/>
	        </xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="ConversaoUniaoEstavel" use="required">
			<xsd:simpleType>
		      <xsd:restriction base="IndicadorSimNao"/>
	        </xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="SeparacaoObrigatoriaBens" use="required">
			<xsd:simpleType>
		      <xsd:restriction base="IndicadorSimNao"/>
	        </xsd:simpleType>
		</xsd:attribute>
		</xsd:extension>
	</xsd:complexContent>
  </xsd:complexType>

  <xsd:complexType name="AtoJuizPaz">
    <xsd:complexContent>
      <xsd:extension base="Transmissao">
        <xsd:sequence>
          <xsd:element name="AtosVinculados" type="tpAtosVinculados" minOccurs="1" maxOccurs="1"/>
		  <xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
        </xsd:sequence>        
      </xsd:extension>
    </xsd:complexContent>
  </xsd:complexType>

  <xsd:complexType name="AtoCertidaoHabilitacaoCasamento">
	<xsd:complexContent>
		<xsd:extension base="Ato">
		<xsd:sequence>
				<xsd:element name="Conjuges" type="tpConjuge" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="AtosVinculados" type="tpAtosVinculados" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
		</xsd:sequence>
		<xsd:attribute name="ProcessoHabilitacao" use="required">
			<xsd:simpleType>
		      <xsd:restriction base="string25"/>
	        </xsd:simpleType>
		</xsd:attribute>
		</xsd:extension>
	</xsd:complexContent>
  </xsd:complexType>

   <xsd:complexType name="AtoRegistroCasamento">
	<xsd:complexContent>
		<xsd:extension base="Ato">
		<xsd:sequence>
				<xsd:element name="Conjuges" type="tpConjuge" minOccurs="1" maxOccurs="1"/>
				<xsd:element name="ImpressosSeguranca" type="tpImpressosSeguranca" minOccurs="0" maxOccurs="1"/>
				<xsd:element name="AtosVinculados" type="tpAtosVinculados" minOccurs="0" maxOccurs="1"/>
				<xsd:element name="Emolumentos" type="tpEmolumentos" minOccurs="1" maxOccurs="1"/>
		</xsd:sequence>
		<xsd:attribute name="DataCasamento" use="required">
			<xsd:simpleType>
				<xsd:restriction base="DataFormatoBrasil"/>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="DataPublicacaoProclamas" >
			<xsd:simpleType>
				<xsd:restriction base="DataFormatoBrasil"/>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="TipoCelebrante" use="required">
			<xsd:simpleType>
				<xsd:restriction base="xsd:string">
					<xsd:enumeration value="1"/>
					<xsd:enumeration value="2"/>
					<xsd:enumeration value="3"/>
					<xsd:enumeration value="4"/>
					</xsd:restriction>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="TipoUniao" use="required">
			<xsd:simpleType>
				<xsd:restriction base="xsd:string">
					<xsd:enumeration value="1"/>
					<xsd:enumeration value="2"/>
					</xsd:restriction>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="TipoCasamento" use="required">
			<xsd:simpleType>
				<xsd:restriction base="xsd:string">
					<xsd:enumeration value="1"/>
					<xsd:enumeration value="2"/>
					<xsd:enumeration value="3"/>
					<xsd:enumeration value="4"/>
					<xsd:enumeration value="5"/>
					<xsd:enumeration value="6"/>
					<xsd:enumeration value="7"/>
					</xsd:restriction>
			</xsd:simpleType>
		</xsd:attribute>
		<xsd:attribute name="RegimeCasamento" >
			<xsd:simpleType>
				<xsd:restriction base="xsd:string">
					<xsd:enumeration value="1"/>
					<xsd:enumeration value="2"/>
